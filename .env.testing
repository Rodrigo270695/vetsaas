APP_ENV=testing
APP_KEY=base64:ulet3AZpshrKy2wF6QQ3TF+Qh+XrvEjj+KruUfyX1Zo=
APP_DEBUG=true
APP_URL=http://localhost

APP_TIMEZONE=America/Lima
APP_LOCALE=es
APP_FALLBACK_LOCALE=es

BCRYPT_ROUNDS=4

# ─────────────────────────────────────────────────────────────────────
# BLINDAJE: los tests JAMÁS deben tocar la BD real (vetsaas en pgsql).
# Si necesitas correr tests contra Postgres real (multi-schema), hazlo
# de forma explícita exportando DB_CONNECTION=pgsql_test antes de pest.
# ─────────────────────────────────────────────────────────────────────
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

SESSION_DRIVER=array
CACHE_STORE=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
BROADCAST_CONNECTION=null

PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false

# Multi-tenancy en testing (los tests de Tenancy que requieren pgsql
# se saltan automáticamente si el driver no es pgsql)
TENANT_CENTRAL_DOMAINS="localhost,127.0.0.1,vetsaas.test"
TENANT_ROOT_DOMAIN=vetsaas.test
TENANT_SCHEMA_PREFIX=vet_
TENANT_CACHE_TTL=0
