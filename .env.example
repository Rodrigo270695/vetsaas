APP_NAME=VetSaaS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_TIMEZONE=America/Lima
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

# Superadmin de la plataforma VetSaaS (tabla platform_admins, guard platform)
PLATFORM_SUPERADMIN_NAME="Super administrador"
PLATFORM_SUPERADMIN_EMAIL=
PLATFORM_SUPERADMIN_PASSWORD=

# Solo al migrar el tenant: schema PostgreSQL destino (ver database/migrations/tenant/README.md)
# TENANT_MIGRATION_SCHEMA=vet_a1b2c3

# Tests Pest que ejecutan `vetsaas:tenant-migrate` / `migrate:fresh` contra Postgres: omiten la suite
# si DB_DATABASE no termina en `_test` o `_testing` (p. ej. usa `vetsaas_test`, no la misma que desarrollo).
# VETSAAS_ALLOW_TENANT_MIGRATE_TESTS=false

# Integración Orvae PE -> VetSaaS (provisioning firmado HMAC, igual que Aula Virtual)
# El mismo secret debe estar en Orvae PE como AULAVIRTUAL_PROVISION_HMAC_SECRET
# (o el equivalente VETSAAS_PROVISION_HMAC_SECRET cuando se lance la integración VetSaaS).
ORVAE_PROVISION_HMAC_SECRET=
ORVAE_PROVISION_MAX_SKEW_SECONDS=300
ORVAE_PROVISION_IDEMPOTENCY_TTL_DAYS=30

# Dominio base donde cada tenant tiene su subdominio (slug.{VETSAAS_TENANT_DOMAIN})
VETSAAS_TENANT_SCHEME=https
VETSAAS_TENANT_DOMAIN=vetsaas.orvae.pe
VETSAAS_TENANT_LOGIN_PATH=/login

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Backups PostgreSQL (vetsaas:backup-database, diario 02:00 vía schedule)
BACKUP_ENABLED=true
# BACKUP_PATH=/var/backups/vetsaas
BACKUP_RETENTION_DAYS=14
BACKUP_PG_DUMP=pg_dump
BACKUP_STALE_AFTER_HOURS=30

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
# false = reset de contraseña se envía en el request (recomendado sin worker de colas)
MAIL_QUEUE_AUTH_NOTIFICATIONS=false
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Multi-tenancy en runtime ──
# Hosts que NO son tenants (panel del superadmin)
TENANT_CENTRAL_DOMAINS="localhost,127.0.0.1,vetsaas.test"
# Sufijo desde el cual se extrae el slug del subdominio
TENANT_ROOT_DOMAIN=vetsaas.test
# Prefijo obligatorio en schema_name. Vacío = sin restricción.
TENANT_SCHEMA_PREFIX=vet_
# Segundos de cache para la resolución tenant → schema. 0 = sin cache.
TENANT_CACHE_TTL=60

# API SUNAT / RUC (apiperu.dev) — solo servidor; consulta DNI/RUC al registrar propietario/proveedor
APIPERU_BASE_URL=https://apiperu.dev/api
APIPERU_TOKEN=

# Lucode / APISUNAT — respaldo si apiperu agota cuota (token de app.apisunat.pe → Organización → API Token)
# Si se omite, se usa el token APISUNAT configurado en la clínica (Configuración › General).
APISUNAT_LOOKUP_BASE_URL=https://dev.apisunat.pe/api/v1
APISUNAT_LOOKUP_TOKEN=

# OpenWA — gateway WhatsApp self-hosted (wa.vetsaas.orvae.pe)
OPENWA_ENABLED=false
OPENWA_API_URL=https://wa.vetsaas.orvae.pe
OPENWA_API_KEY=
OPENWA_ADMIN_URL=https://wa-admin.vetsaas.orvae.pe
OPENWA_TIMEOUT_SECONDS=30
OPENWA_QUEUE_MAX_ATTEMPTS=3
OPENWA_PLATFORM_SESSION_NAME=vetsaas-platform

# Recordatorios de renovación de suscripción (WhatsApp plataforma → tenant)
BILLING_RENEWAL_REMINDER_DAYS=7,3,1
# Checkout Orvae: base o plantilla con {tenant} {plan} {ciclo}
ORVAE_RENEWAL_URL=https://orvae.pe/renovar/vetsaas?tenant={tenant}&plan={plan}&ciclo={ciclo}

# Asistente IA — activación del add-on vía WhatsApp soporte
BOT_IA_ACTIVATION_WHATSAPP_PHONE=51976809804
BOT_IA_ACTIVATION_WHATSAPP_DISPLAY="976 809 804"

# Wizard de configuración inicial (clínicas)
# ONBOARDING_ENABLED=true activa el wizard para todos los tenants incompletos.
# ONBOARDING_ENABLED_SLUGS permite probar solo en tenants concretos (ej. demo,mi-prueba).
ONBOARDING_ENABLED=false
ONBOARDING_ENABLED_SLUGS=
ONBOARDING_PREVIEW=false
