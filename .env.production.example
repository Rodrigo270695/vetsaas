# =============================================================================
# VetSaaS — PLANTILLA PRODUCCIÓN
# =============================================================================
# Copia en el servidor como .env y rellena los valores marcados con CAMBIAR.
# NO subas este archivo con secretos reales a git.
#
# Arquitectura DNS recomendada (Parte 1):
#   - Panel superadmin (central):  https://vetsaas.orvae.pe
#   - Clínicas (tenants):          https://{slug}.vetsaas.orvae.pe
#   - API provisión Orvae:         https://vetsaas.orvae.pe/api/internal/saas/provision
# =============================================================================

APP_NAME=VetSaaS
APP_ENV=production
APP_KEY=                           # CAMBIAR: php artisan key:generate --show (solo una vez)
APP_DEBUG=false
APP_URL=https://vetsaas.orvae.pe   # CAMBIAR: URL del panel central (sin barra final)

APP_TIMEZONE=America/Lima
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

# Superadmin plataforma (crear con seeder o tinker tras migrate)
PLATFORM_SUPERADMIN_NAME="Super administrador"
PLATFORM_SUPERADMIN_EMAIL=          # CAMBIAR
PLATFORM_SUPERADMIN_PASSWORD=       # CAMBIAR (solo para seed inicial; luego cambiar)

# Provisión desde Orvae PE (mismo secret en Orvae: VETSAAS_PROVISION_HMAC_SECRET)
ORVAE_PROVISION_HMAC_SECRET=        # CAMBIAR: openssl rand -hex 32
ORVAE_PROVISION_MAX_SKEW_SECONDS=300
ORVAE_PROVISION_IDEMPOTENCY_TTL_DAYS=30

# URLs de login que Orvae devuelve al cliente tras el pago
VETSAAS_TENANT_SCHEME=https
VETSAAS_TENANT_DOMAIN=vetsaas.orvae.pe
VETSAAS_TENANT_LOGIN_PATH=/login

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# PostgreSQL producción (obligatorio para multi-tenant por schema)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1                       # CAMBIAR si DB en otro host
DB_PORT=5432
DB_DATABASE=vetsaas                     # CAMBIAR
DB_USERNAME=vetsaas                     # CAMBIAR
DB_PASSWORD=                            # CAMBIAR

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# null = cookie por host (recomendado: cada subdominio de clínica aislado).
# Si en el futuro necesitas cookie compartida: SESSION_DOMAIN=.vetsaas.orvae.pe

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Correo transaccional (invitaciones, reset password). NO uses "log" en producción.
MAIL_MAILER=smtp
# false = envía reset/invitación al instante (sin queue:work). true = cola "mails".
MAIL_QUEUE_AUTH_NOTIFICATIONS=false
MAIL_HOST=                              # CAMBIAR
MAIL_PORT=587
MAIL_USERNAME=                          # CAMBIAR
MAIL_PASSWORD=                          # CAMBIAR
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@vetsaas.orvae.pe
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Multi-tenancy
# Host del panel Plataforma (NO es tenant). Puede ser el apex vetsaas.orvae.pe
TENANT_CENTRAL_DOMAINS=vetsaas.orvae.pe
# Sufijo de subdominios de clínicas: clinica-x.vetsaas.orvae.pe → slug clinica-x
TENANT_ROOT_DOMAIN=vetsaas.orvae.pe
# Debe coincidir con VETSAAS_TENANT_DOMAIN (URLs que envía Orvae al cliente).
TENANT_SCHEMA_PREFIX=vet_
TENANT_CACHE_TTL=300

# Tablas de framework siempre en public (multi-tenant por schema)
SESSION_TABLE=public.sessions
DB_CACHE_TABLE=public.cache
DB_CACHE_LOCK_TABLE=public.cache_locks

# No activar en producción salvo migraciones controladas
# TENANT_MIGRATION_SCHEMA=
# VETSAAS_ALLOW_TENANT_MIGRATE_TESTS=false

APIPERU_BASE_URL=https://apiperu.dev/api
APIPERU_TOKEN=                          # CAMBIAR si usas consulta RUC
